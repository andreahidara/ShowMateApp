root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
ktlint_code_style = android_studio
# Allow wildcard imports for Compose (standard practice)
ij_kotlin_packages_to_use_import_on_demand = androidx.compose.animation.*,androidx.compose.animation.core.*,androidx.compose.foundation.layout.*,androidx.compose.material.icons.filled.*,androidx.compose.material.icons.outlined.*,androidx.compose.material3.*,androidx.compose.runtime.*,androidx.compose.ui.*,com.andrea.showmateapp.ui.components.premium.*,com.andrea.showmateapp.ui.screens.home.components.*,com.andrea.showmateapp.ui.theme.*,java.util.*
# Allow PascalCase for @Composable functions (Compose naming convention)
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.gradle.kts]
indent_size = 4

[*.xml]
max_line_length = off
indent_size = 4

[*.md]
trim_trailing_whitespace = false
