root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
ktlint_code_style = android_studio
# Allow wildcard imports for Compose (standard practice)
ij_kotlin_packages_to_use_import_on_demand = androidx.compose.foundation.layout.*,androidx.compose.material3.*,androidx.compose.runtime.*,androidx.compose.ui.*

[*.gradle.kts]
indent_size = 4

[*.xml]
max_line_length = off
indent_size = 4

[*.md]
trim_trailing_whitespace = false
