<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ShowMateApp" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#0F0A1E</item>
        <item name="android:statusBarColor">#0F0A1E</item>
        <item name="android:navigationBarColor">#0F0A1E</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F0A1E</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.ShowMateApp</item>
    </style>
</resources>
